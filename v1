<style>
:root {
  --ink: #1a1f28;
  --deep: #2a3744;
  --deep-soft: #3d4a58;
  --cream: #ebe3d1;
  --cream-light: #f5efe2;
  --cream-dark: #d8ceb7;
  --accent: #b8954e;
  --accent-deep: #8c6e36;
  --line: rgba(42, 55, 68, 0.14);
  --line-strong: rgba(42, 55, 68, 0.3);
  --font-display: 'Fraunces', 'Noto Serif SC', Georgia, serif;
  --font-sans: 'DM Sans', 'Noto Sans SC', -apple-system, sans-serif;
  --font-cn-serif: 'Noto Serif SC', 'Fraunces', serif;
  --max-w: 1340px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }

body {
  font-family: var(--font-sans);
  color: var(--ink);
  background: var(--cream);
  line-height: 1.6;
  overflow-x: hidden;
}

body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 10%, rgba(184,149,78,0.06), transparent 40%),
    radial-gradient(circle at 80% 80%, rgba(42,55,68,0.05), transparent 45%);
  pointer-events: none;
  z-index: 1;
}

img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }

/* ---------------- NAV ---------------- */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 22px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background .4s ease, padding .3s ease, backdrop-filter .3s ease;
}
.nav.scrolled {
  background: rgba(235,227,209,0.85);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  padding: 14px 40px;
  border-bottom: 1px solid var(--line);
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 500;
  letter-spacing: 0.02em;
  color: var(--deep);
}
.nav-logo img {
  height: 38px;
  width: auto;
}
.nav-logo .mark {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.nav-logo .mark-cn {
  font-family: var(--font-cn-serif);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.12em;
  color: var(--deep);
}
.nav-logo .mark-en {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 400;
  letter-spacing: 0.25em;
  color: var(--deep-soft);
  text-transform: uppercase;
  margin-top: 3px;
}
.nav-links {
  display: flex;
  gap: 40px;
  align-items: center;
  list-style: none;
}
.nav-links a {
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--deep);
  position: relative;
  padding: 4px 0;
  transition: color .3s;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -2px; left: 0;
  width: 0; height: 1px;
  background: var(--accent);
  transition: width .4s ease;
}
.nav-links a:hover { color: var(--accent-deep); }
.nav-links a:hover::after { width: 100%; }
.nav-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  flex-direction: column;
  gap: 5px;
  padding: 6px;
}
.nav-toggle span {
  width: 26px; height: 1.5px;
  background: var(--deep);
  transition: .3s;
}

/* ---------------- HERO ---------------- */
.hero {
  min-height: 100vh;
  padding: 140px 40px 80px;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  z-index: 2;
}
.hero-grid-lines {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.4;
}
.hero-grid-lines::before,
.hero-grid-lines::after {
  content: '';
  position: absolute;
  background: var(--line);
}
.hero-grid-lines::before {
  top: 0; bottom: 0;
  left: 12%;
  width: 1px;
}
.hero-grid-lines::after {
  top: 0; bottom: 0;
  right: 12%;
  width: 1px;
}
.hero-inner {
  max-width: var(--max-w);
  width: 100%;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
}
.hero-kicker {
  font-size: 12px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-deep);
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 14px;
  opacity: 0;
  animation: fadeUp .9s .2s forwards;
}
.hero-kicker::before {
  content: '';
  width: 40px; height: 1px;
  background: var(--accent-deep);
}
.hero-title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(52px, 8.2vw, 124px);
  line-height: 0.95;
  letter-spacing: -0.02em;
  color: var(--deep);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 1s .35s forwards;
}
.hero-title em {
  font-style: italic;
  font-weight: 400;
  color: var(--accent-deep);
}
.hero-title-cn {
  font-family: var(--font-cn-serif);
  font-weight: 400;
  font-size: clamp(22px, 2.6vw, 32px);
  letter-spacing: 0.5em;
  color: var(--deep-soft);
  margin-bottom: 40px;
  opacity: 0;
  animation: fadeUp 1s .5s forwards;
}
.hero-lede {
  font-family: var(--font-display);
  font-weight: 300;
  font-style: italic;
  font-size: clamp(17px, 1.5vw, 22px);
  line-height: 1.55;
  color: var(--deep-soft);
  max-width: 520px;
  margin-bottom: 48px;
  opacity: 0;
  animation: fadeUp 1s .65s forwards;
}
.hero-cta {
  display: flex;
  gap: 18px;
  opacity: 0;
  animation: fadeUp 1s .8s forwards;
}
.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 28px;
  font-size: 13px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  font-weight: 500;
  transition: all .35s ease;
  border: 1px solid transparent;
  cursor: pointer;
}
.btn-primary {
  background: var(--deep);
  color: var(--cream);
}
.btn-primary:hover {
  background: var(--ink);
  transform: translateY(-2px);
}
.btn-ghost {
  color: var(--deep);
  border-color: var(--line-strong);
}
.btn-ghost:hover {
  border-color: var(--deep);
  background: rgba(42,55,68,0.04);
}
.btn svg { transition: transform .35s ease; }
.btn:hover svg { transform: translateX(4px); }

.hero-logo-wrap {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  animation: fadeIn 1.4s .3s forwards;
}
.hero-logo-wrap::before {
  content: '';
  position: absolute;
  width: 108%;
  height: 108%;
  border: 1px solid var(--line-strong);
  border-radius: 50%;
  animation: rotateSlow 40s linear infinite;
}
.hero-logo-wrap::after {
  content: '';
  position: absolute;
  width: 80%;
  height: 80%;
  border: 1px dashed var(--line);
  border-radius: 50%;
  animation: rotateSlow 50s linear infinite reverse;
}
.hero-logo {
  width: min(420px, 90%);
  filter: drop-shadow(0 14px 40px rgba(42,55,68,0.12));
  animation: floatSoft 6s ease-in-out infinite;
}

.hero-meta {
  position: absolute;
  bottom: 40px;
  left: 40px;
  right: 40px;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--deep-soft);
  opacity: 0;
  animation: fadeIn 1s 1.2s forwards;
}
.hero-meta .scroll-hint {
  display: flex;
  align-items: center;
  gap: 10px;
}
.hero-meta .scroll-hint::before {
  content: '';
  width: 1px; height: 24px;
  background: var(--deep-soft);
  animation: scrollLine 2s ease-in-out infinite;
}

/* ---------------- SECTION BASE ---------------- */
section {
  position: relative;
  z-index: 2;
}
.section-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 120px 40px;
}
.section-label {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  font-size: 11px;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--accent-deep);
  margin-bottom: 32px;
  font-weight: 500;
}
.section-label::before {
  content: '';
  width: 28px; height: 1px;
  background: var(--accent-deep);
}
.section-label .num {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 13px;
  letter-spacing: 0;
}

/* ---------------- ABOUT ---------------- */
.about {
  background: var(--cream-light);
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 80px;
  align-items: start;
}
.about-heading {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(34px, 4.5vw, 58px);
  line-height: 1.05;
  letter-spacing: -0.015em;
  color: var(--deep);
  margin-bottom: 24px;
}
.about-heading em {
  font-style: italic;
  color: var(--accent-deep);
}
.about-sub-cn {
  font-family: var(--font-cn-serif);
  font-size: clamp(18px, 1.6vw, 22px);
  color: var(--deep-soft);
  letter-spacing: 0.15em;
  line-height: 1.7;
}
.about-body p {
  font-size: 16px;
  line-height: 1.85;
  color: var(--deep);
  margin-bottom: 22px;
}
.about-body p:first-child::first-letter {
  font-family: var(--font-display);
  font-size: 58px;
  font-weight: 400;
  float: left;
  line-height: 1;
  padding: 8px 14px 0 0;
  color: var(--accent-deep);
}
.about-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-top: 60px;
  border-top: 1px solid var(--line);
}
.about-stat {
  padding: 32px 20px 0 0;
  border-right: 1px solid var(--line);
}
.about-stat:last-child { border-right: none; padding-right: 0; }
.about-stat .n {
  font-family: var(--font-display);
  font-size: clamp(36px, 4vw, 52px);
  font-weight: 400;
  line-height: 1;
  color: var(--deep);
  margin-bottom: 8px;
}
.about-stat .n em { font-style: italic; color: var(--accent-deep); }
.about-stat .l {
  font-size: 12px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--deep-soft);
}

/* ---------------- SERVICES ---------------- */
.services-header {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: end;
  margin-bottom: 80px;
}
.services-title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(40px, 5.5vw, 76px);
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--deep);
}
.services-title em {
  font-style: italic;
  color: var(--accent-deep);
}
.services-intro {
  font-size: 15px;
  line-height: 1.8;
  color: var(--deep-soft);
  max-width: 440px;
  justify-self: end;
}
.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--line);
  border: 1px solid var(--line);
}
.service {
  background: var(--cream);
  padding: 48px 44px;
  position: relative;
  overflow: hidden;
  transition: background .4s ease;
  min-height: 340px;
  display: flex;
  flex-direction: column;
}
.service:hover { background: var(--cream-light); }
.service::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 0; height: 2px;
  background: var(--accent);
  transition: width .6s ease;
}
.service:hover::after { width: 100%; }
.service-num {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 14px;
  color: var(--accent-deep);
  margin-bottom: 28px;
  letter-spacing: 0.05em;
}
.service-icon {
  width: 48px; height: 48px;
  margin-bottom: 28px;
  color: var(--deep);
  transition: transform .5s ease;
}
.service:hover .service-icon {
  transform: translateY(-4px) rotate(-4deg);
  color: var(--accent-deep);
}
.service-title {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: 30px;
  color: var(--deep);
  margin-bottom: 6px;
  line-height: 1.1;
}
.service-title-cn {
  font-family: var(--font-cn-serif);
  font-size: 15px;
  letter-spacing: 0.2em;
  color: var(--deep-soft);
  margin-bottom: 20px;
}
.service-desc {
  font-size: 14.5px;
  line-height: 1.75;
  color: var(--deep-soft);
  margin-top: auto;
}

/* ---------------- BRAND PAPYLLON ---------------- */
.brand {
  background: var(--deep);
  color: var(--cream);
  overflow: hidden;
}
.brand .section-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.brand-label {
  color: #c9a66a;
}
.brand-label::before { background: #c9a66a; }
.brand-title {
  font-family: var(--font-display);
  font-weight: 300;
  font-style: italic;
  font-size: clamp(56px, 8vw, 110px);
  line-height: 0.9;
  letter-spacing: -0.02em;
  color: var(--cream);
  margin-bottom: 12px;
}
.brand-title-cn {
  font-family: var(--font-cn-serif);
  font-size: clamp(22px, 2.4vw, 32px);
  letter-spacing: 0.5em;
  color: var(--cream-dark);
  margin-bottom: 36px;
  font-weight: 300;
}
.brand-desc {
  font-family: var(--font-display);
  font-weight: 300;
  font-style: italic;
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.65;
  color: var(--cream-dark);
  margin-bottom: 32px;
  max-width: 520px;
}
.brand-desc-cn {
  font-size: 15px;
  line-height: 1.9;
  color: rgba(235,227,209,0.75);
  max-width: 520px;
  margin-bottom: 40px;
}
.brand-meta {
  display: flex;
  gap: 50px;
  padding-top: 30px;
  border-top: 1px solid rgba(235,227,209,0.2);
}
.brand-meta .m {
  font-size: 11px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: rgba(235,227,209,0.6);
  margin-bottom: 8px;
}
.brand-meta .v {
  font-family: var(--font-display);
  font-size: 20px;
  color: var(--cream);
}

.brand-visual {
  position: relative;
  aspect-ratio: 1 / 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
}
.brand-visual::before {
  content: 'P';
  position: absolute;
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 300;
  font-size: clamp(280px, 40vw, 560px);
  color: rgba(201,166,106,0.08);
  line-height: 1;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
.brand-mark {
  position: relative;
  z-index: 2;
  text-align: center;
}
.brand-mark .p-large {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 300;
  font-size: clamp(120px, 16vw, 220px);
  color: #c9a66a;
  line-height: 1;
  letter-spacing: -0.04em;
}
.brand-mark .p-sub {
  font-family: var(--font-display);
  font-size: 14px;
  letter-spacing: 0.5em;
  color: var(--cream-dark);
  text-transform: uppercase;
  margin-top: 10px;
}
.brand-mark .p-line {
  width: 60px; height: 1px;
  background: #c9a66a;
  margin: 20px auto;
}
.brand-mark .p-cn {
  font-family: var(--font-cn-serif);
  font-size: 16px;
  letter-spacing: 0.4em;
  color: var(--cream);
  font-weight: 300;
}

/* ---------------- CONTACT ---------------- */
.contact {
  background: var(--cream);
  border-top: 1px solid var(--line);
}
.contact-header {
  text-align: center;
  margin-bottom: 80px;
}
.contact-title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(44px, 6.5vw, 92px);
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--deep);
  margin-bottom: 18px;
}
.contact-title em { font-style: italic; color: var(--accent-deep); }
.contact-sub {
  font-family: var(--font-cn-serif);
  font-size: clamp(16px, 1.4vw, 20px);
  letter-spacing: 0.3em;
  color: var(--deep-soft);
}
.contact-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}
.contact-item {
  padding: 50px 40px;
  border-right: 1px solid var(--line);
  position: relative;
}
.contact-item:last-child { border-right: none; }
.contact-item .ci-num {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 13px;
  color: var(--accent-deep);
  margin-bottom: 20px;
}
.contact-item .ci-label {
  font-size: 11px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--deep-soft);
  margin-bottom: 14px;
}
.contact-item .ci-value {
  font-family: var(--font-display);
  font-size: 20px;
  line-height: 1.4;
  color: var(--deep);
  margin-bottom: 10px;
  word-break: break-word;
}
.contact-item .ci-value-cn {
  font-family: var(--font-cn-serif);
  font-size: 15px;
  line-height: 1.75;
  color: var(--deep-soft);
}
.contact-item a.ci-value:hover { color: var(--accent-deep); }

.contact-note {
  text-align: center;
  margin-top: 60px;
  font-family: var(--font-display);
  font-style: italic;
  font-size: 18px;
  color: var(--deep-soft);
}

/* ---------------- FOOTER ---------------- */
.footer {
  background: var(--ink);
  color: var(--cream-dark);
  padding: 60px 40px 30px;
  position: relative;
  z-index: 2;
}
.footer-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr;
  gap: 60px;
  padding-bottom: 40px;
  border-bottom: 1px solid rgba(235,227,209,0.15);
}
.footer-brand {
  display: flex;
  align-items: flex-start;
  gap: 18px;
}
.footer-brand img { height: 54px; }
.footer-brand .fb-text {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.footer-brand .fb-cn {
  font-family: var(--font-cn-serif);
  font-size: 16px;
  color: var(--cream);
  letter-spacing: 0.08em;
  font-weight: 400;
